# AIOStreams bootstrap config (copy to .env and edit).
# Full reference: https://docs.aiostreams.viren070.me/configuration/environment-variables
#
# setup-aiostreams.cmd generates SECRET_KEY for you on first run.

# Public URL of this instance (include protocol; add port when not behind a reverse proxy).
BASE_URL=http://localhost:3000

# 64-char hex encryption key — REQUIRED. setup-aiostreams.cmd generates this.
# Do not change after first run or stored addon configs become unreadable.
SECRET_KEY=

# SQLite database (relative to AIOStreams/repo/ when the server runs).
DATABASE_URI=sqlite://./data/db.sqlite

# Listen port (must match BASE_URL unless you reverse-proxy).
PORT=3000

# Optional operator login for /stremio/configure (comma-separated user:pass pairs).
# AIOSTREAMS_AUTH=admin:changeme

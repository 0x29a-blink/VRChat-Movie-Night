# Copy to .env — never commit .env (gitignored).
#
# Tokens go HERE (cloudflare/.env), not in backend/.env.
#
# --- Option A: one tunnel, two public hostnames in Cloudflare dashboard ---
# CF_TUNNEL_TOKEN=
#
# --- Option B: two separate tunnels (one token each) ---
CF_TUNNEL_TOKEN_APP=
CF_TUNNEL_TOKEN_STREAM=
#
# Configure each tunnel's public hostname in Cloudflare:
#   app tunnel    →  HTTP  localhost:8000   (movienight.yourdomain.com)
#   stream tunnel →  HTTP  localhost:8888   (stream.yourdomain.com)
#
# backend/.env (separate file — no tunnel tokens):
#   BEHIND_PROXY=true
#   HLS_PUBLIC_BASE_URL=https://stream.yourdomain.com

# ---- Copy this file to ".env" and fill in your values ----

# Bootstrap admin password (used only on first run by bootstrap.py to create the admin user).
# After that, create accounts for friends on Settings → Users and change passwords there.
APP_PASSWORD=changeme

# Secret used to sign session cookies. Change this to a long random string before exposing the app.
SECRET_KEY=please-change-this-to-a-long-random-string

# ---- OBS WebSocket (Tools -> WebSocket Server Settings in OBS) ----
OBS_HOST=localhost
OBS_PORT=4455
# Change the default OBS WebSocket password in OBS and here.
OBS_PASSWORD=changeme
# Name of the Media Source in OBS that we control for playback
OBS_MEDIA_INPUT=VRStream
# Optional: scene to switch to before playing (leave blank to skip)
OBS_SCENE=

# ---- Metadata + Torrent search ----
# TMDB API key (themoviedb.org -> Settings -> API)
TMDB_API_KEY=
# AIOStreams base = manifest URL BEFORE "/manifest.json" (optional).
# Leave blank to auto-detect from local AIOStreams\ after saving /stremio/configure.
# Override only for remote/public instances:
#   https://aiostreams.elfhosted.com/stremio/<your-config>
AIOSTREAMS_BASE=
# TorBox API key (torbox.app) — for "Cache & download" on uncached torrents
TORBOX_API_KEY=

# ---- Downloads ----
MAX_CONCURRENT_DOWNLOADS=2
# yt-dlp uses deno as a JS runtime (matches your download.cmd). Set false if unsupported.
USE_DENO=true

# ---- Tool paths (leave as-is to use PATH) ----
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
ARIA2C_PATH=aria2c
